```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
node_modules/

# Build outputs
frontend/dist/

# Environment variables
.env
.env.local
.env.*

# IDE specific
.vscode/
.idea/

# Logs
*.log

# Coverage reports
.coverage
htmlcov/
coverage/

# Temporary files
*.tmp
*.temp
*.swp
*.swo

# OS generated
.DS_Store
Thumbs.db

# Package lock files
frontend/package-lock.json

# Compressed archives
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```